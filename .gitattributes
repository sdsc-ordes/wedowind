# Append-only JSONL logs (large over time; store pointer files in git, blobs in LFS).
catalog/logs/*.jsonl filter=lfs diff=lfs merge=lfs -text

# Catalog group JSON (human-edited; track via LFS like logs).
catalog/groups/** filter=lfs diff=lfs merge=lfs -text

# Mapper sources registry + per-run timestamp checkpoints (CI updates).
src/mappers/*/config/sources.json filter=lfs diff=lfs merge=lfs -text
src/mappers/*/config/timestamp.json filter=lfs diff=lfs merge=lfs -text
