{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wedowind:catalog-group-entry",
  "title": "CatalogGroup",
  "description": "Human-readable catalog group file with artifacts and versions to publish.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "abstract": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "required": ["id", "title", "abstract", "description"]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "abstract": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "versions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "title": { "type": "string", "minLength": 1 },
                "abstract": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "license": { "type": "string", "minLength": 1 },
                "distributions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "downloadURL": { "type": "string", "minLength": 1 },
                      "formatExtension": { "type": "string", "minLength": 1 },
                      "compression": { "type": "string" }
                    },
                    "required": ["downloadURL", "formatExtension"]
                  }
                }
              },
              "required": ["id", "title", "abstract", "description", "license", "distributions"]
            }
          }
        },
        "required": ["id", "title", "abstract", "description", "versions"]
      }
    }
  },
  "required": ["group", "artifacts"]
}
