{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wedowind:discrepancy-log-entry",
  "title": "DiscrepancyLogEntry",
  "description": "One catalog vs Databus field mismatch when remote metadata differs from local files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the discrepancy was detected (ISO 8601)."
    },
    "entity_id": {
      "type": "string",
      "minLength": 1,
      "description": "URI @id of the Group, Artefact, or Version node."
    },
    "entity_type": {
      "type": "string",
      "enum": ["group", "artefact", "version"],
      "description": "Which kind of entity the metadata applies to."
    },
    "metadata_field": {
      "type": "string",
      "description": "Literal field name; valid values depend on entity_type.",
      "enum": ["title", "abstract", "description", "license", "distribution"]
    },
    "remote_value": {
      "description": "Value on OEP Databus after fetch (JSON)."
    },
    "local_value": {
      "description": "Value in the local catalog before pull (JSON)."
    }
  },
  "required": [
    "timestamp",
    "entity_id",
    "entity_type",
    "metadata_field",
    "remote_value",
    "local_value"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "entity_type": { "const": "group" } },
        "required": ["entity_type"]
      },
      "then": {
        "description": "Group fields match the Group node in catalog group-metadata.jsonld (OEP context): title, abstract, description.",
        "properties": {
          "metadata_field": { "enum": ["title", "abstract", "description"] }
        }
      }
    },
    {
      "if": {
        "properties": { "entity_type": { "const": "artefact" } },
        "required": ["entity_type"]
      },
      "then": {
        "properties": {
          "metadata_field": { "enum": ["title", "abstract", "description"] }
        }
      }
    },
    {
      "if": {
        "properties": { "entity_type": { "const": "version" } },
        "required": ["entity_type"]
      },
      "then": {
        "properties": {
          "metadata_field": {
            "enum": ["title", "abstract", "description", "license", "distribution"]
          }
        }
      }
    }
  ]
}
